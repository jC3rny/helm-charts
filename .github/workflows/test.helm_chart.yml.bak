name: Test Helm chart
  
on: pull_request

env:
  HELM_CHARTS_ROOT_PATH: charts

jobs:
  test_helm_chart:

    runs-on: ubuntu-latest
    
    steps:
      - uses: actions/checkout@v2

      - uses: azure/setup-helm@v1
      
      - name: Lint
        run: |
          git log --name-status -n 1
          echo ""
          git log --name-only --pretty=format: -n 1 -- ${{ env.HELM_CHARTS_ROOT_PATH }} | find -name "Chart.yaml" | xargs dirname | xargs helm lint